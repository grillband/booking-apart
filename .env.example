# Smart Order Booking API v3 credentials
# When all three are set, the app connects to the real Smart Order API.
# When unset, mock data is used for local development.

SMARTORDER_API_KEY=
SMARTORDER_BASE_URL=
SMARTORDER_HOTEL_ID=

# Payment type sent to Smart Order when creating reservations.
# Common values: PayAtHotel, Prepaid, CreditCard
# Defaults to PayAtHotel if not set.
SMARTORDER_PAYMENT_TYPE=PayAtHotel
